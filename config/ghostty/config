# vim: filetype=config

font-family = Lambda
font-size = 19
font-feature = -calt, -liga, -dlig
shell-integration = none

cursor-style = block
adjust-cursor-thickness = 2
# custom-shader = ./cursor_fade.glsl
custom-shader-animation = true
mouse-hide-while-typing = true

macos-titlebar-style = native
macos-non-native-fullscreen = true
window-decoration = false
confirm-close-surface = false

window-padding-balance = true
window-padding-x = 0
window-padding-y = 0

link-previews = osc8

# command=tmux new -t terminal -s "terminal-$(tmux list-clients | rg terminal- | wc -l)" -A

background = "#002b36"
foreground = "#97a9a8"

selection-foreground = #FFFFFF
selection-background = #373737

# Cursor colors
# this is a mid point between 2 themes while toggling dark/light mode is
# not supported https://meyerweb.com/eric/tools/color-blend/#643F61:CCFF66:10:hex
cursor-color = green
cursor-text = #1e1e1e

palette = 0=#0f0f0f
palette = 1=#c1626c
palette = 2=#879a1d
palette = 3=#b58900
palette = 4=#498fc8
palette = 5=#b95e83
palette = 6=#4c9f8c
palette = 7=#97a9a8
